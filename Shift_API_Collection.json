{
	"info": {
		"_postman_id": "shift-api-collection",
		"name": "Shift Car Rental API",
		"description": "Collection for testing the Shift Car Rental API requirements",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Vehicles",
			"item": [
				{
					"name": "Create Vehicle",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"manufacturer\": \"Honda\",\n    \"model\": \"Civic\",\n    \"releaseYear\": 2023,\n    \"licensePlate\": \"ABC1234\",\n    \"dailyPrice\": 250.00\n}",
							"options": { "照顾": { "language": "json" } }
						},
						"url": { "raw": "http://localhost:8080/vehicles" }
					}
				},
				{
					"name": "List All Vehicles (Paginated)",
					"request": {
						"method": "GET",
						"url": { "raw": "http://localhost:8080/vehicles?page=0&size=5&sort=model,asc" }
					}
				},
				{
					"name": "Search by Manufacturer",
					"request": {
						"method": "GET",
						"url": { "raw": "http://localhost:8080/vehicles/search/manufacturer?manufacturer=Honda" }
					}
				}
			]
		},
		{
			"name": "Customers",
			"item": [
				{
					"name": "Create Customer",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"John Doe\",\n    \"driverLicense\": \"12345678901\",\n    \"cpf\": \"123.456.789-00\",\n    \"expiryDate\": \"2030-12-31\",\n    \"active\": true\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "http://localhost:8080/customers" }
					}
				}
			]
		},
		{
			"name": "Rentals",
			"item": [
				{
					"name": "Create Rental",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"customerId\": 1,\n    \"vehicleId\": 1,\n    \"startDate\": \"2026-05-01T10:00:00\",\n    \"endDate\": \"2026-05-05T10:00:00\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "http://localhost:8080/rental" }
					}
				},
				{
					"name": "List All Rentals",
					"request": {
						"method": "GET",
						"url": { "raw": "http://localhost:8080/rental" }
					}
				},
				{
					"name": "Search Rental by Customer CPF",
					"request": {
						"method": "GET",
						"url": { "raw": "http://localhost:8080/rental/search/cpf?cpf=123.456.789-00" }
					}
				}
			]
		}
	]
}
